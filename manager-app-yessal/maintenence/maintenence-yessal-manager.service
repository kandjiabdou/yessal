[Unit]
Description=Maintenance Yessal
After=network.target

[Service]
Environment=PORT=4510
Type=simple
User=root
WorkingDirectory=/root/proprojects/yessal/manager-app-yessal/maintenence
ExecStart=/usr/bin/node server.js
Restart=on-failure
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
