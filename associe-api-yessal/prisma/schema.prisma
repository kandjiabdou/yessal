generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id             Int      @id @default(autoincrement())
  role           userrole
  nom            String
  prenom         String
  email          String?  @unique
  telephone      String?  @unique
  motDePasseHash String?
  pourcentageParts Float? @default(0) // % de parts dans l'entreprise
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  flag           Boolean  @default(true)
  
  @@index([createdAt])
  @@index([createdAt, flag])
  @@index([flag])
  @@index([email])
}

enum userrole {
  ADMIN
  ASSOCIE
}