generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model entreprise {
  id                Int      @id @default(autoincrement())
  nom               String
  adresse           String?
  ville             String?
  telephone         String?
  email             String?
  devise            devise   @default(FCFA)
  tauxConversion    Float    @default(655.96) // 1 EUR = X FCFA
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([nom])
}

model user {
  id               Int      @id @default(autoincrement())
  role             userrole
  nom              String
  prenom           String
  email            String?  @unique
  telephone        String?  @unique
  motDePasseHash   String?
  pourcentageParts Float?   @default(0) // % de parts dans l'entreprise
  devisePreference devise   @default(FCFA) // Préférence de devise de l'utilisateur
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  flag             Boolean  @default(true)
  
  @@index([createdAt])
  @@index([createdAt, flag])
  @@index([flag])
  @@index([email])
}

enum userrole {
  ADMIN
  ASSOCIE
}

enum devise {
  FCFA
  EUR
}