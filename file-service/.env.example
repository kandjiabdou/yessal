# File Service - Configuration

# Port du service
PORT=4540

# URL de base du service (pour générer les URLs de téléchargement)
BASE_URL=http://localhost:4540

# Taille maximale des fichiers (en bytes) - 10MB
MAX_FILE_SIZE=10485760

# Nombre maximum de fichiers par upload multiple
MAX_FILES=10

# Stockage local
UPLOAD_DIR=uploads

# Configuration pour le stockage cloud (future utilisation)
# STORAGE_TYPE=local
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# CORS - URLs autorisées
ALLOWED_ORIGINS=http://localhost:4510,http://localhost:4550

# API Keys pour les applications autorisées
API_KEY_MANAGER=manager-api-key-change-in-production
API_KEY_ASSOCIE=associe-api-key-change-in-production
