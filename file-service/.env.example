# File Service - Configuration

# Port du service
PORT=4540

# Secret pour signer les URLs de téléchargement
JWT_SECRET=your-super-secret-key-change-in-production

# Durée de validité des URLs signées (en secondes)
URL_EXPIRY=3600

# Taille maximale des fichiers (en bytes) - 10MB
MAX_FILE_SIZE=10485760

# Nombre maximum de fichiers par upload multiple
MAX_FILES=10

# Stockage local
UPLOAD_DIR=uploads

# Configuration pour le stockage cloud (future utilisation)
# STORAGE_TYPE=local
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# CORS - URLs autorisées
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://manager.yessal.sn,https://client.yessal.sn

# API Keys pour les applications autorisées
API_KEY_MANAGER=manager-api-key-change-in-production
API_KEY_ASSOCIE=associe-api-key-change-in-production
