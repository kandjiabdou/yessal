PORT=4520
NODE_ENV=development
JWT_SECRET=myesyesssalsectres2025KEYS
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=yessal-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
DATABASE_URL="mysql://root:admin@localhost:3306/yessal"
DATABASE_SHARED_URL="mysql://root:admin@localhost:3306/yessal_shared"
LOG_LEVEL=info

# CORS Configuration
# Dev: http://localhost:4510,http://localhost:5555,http://localhost:4520
# Prod: https://manager.yessal.sn,https://api.yessal.sn,https://admin.yessal.sn,https://dev.manager.yessal.sn,https://dev.api.yessal.sn
CORS_ORIGIN="http://localhost:4510,http://localhost:5555,http://localhost:4520,http://127.0.0.1:4510,http://127.0.0.1:5555"

# JWT Secret pour l'authentification admin
JWT_SECRET_ADMIN="your-super-secure-admin-jwt-secret-key-here"

# Redis Configuration for Yessal Dashboard Caching

# Redis connection URL (default: redis://localhost:6379)
# For production, use your Redis server URL
REDIS_URL=redis://localhost:6379

# Redis connection timeout in milliseconds (default: 5000)
REDIS_CONNECT_TIMEOUT=5000

# Cache TTL settings (in seconds)
# Daily stats cache TTL (default: 900 = 15 minutes)
CACHE_DAILY_TTL=900

# Current period cache TTL (default: 3600 = 1 hour)  
CACHE_CURRENT_PERIOD_TTL=3600

# Historical period cache TTL (default: 86400 = 24 hours)
CACHE_HISTORICAL_TTL=86400

# Future period cache TTL (default: 300 = 5 minutes)
CACHE_FUTURE_TTL=300

BACKUP_DIR="Directory_path_where_backups_will_be_stored"