# Configuration de production pour l'API Yessal
NODE_ENV=production
PORT=4520

# Base de données
DATABASE_URL="your_production_database_url_here"

# Base de données partagée (pour les flux financiers)
DATABASE_SHARED_URL="mysql://user:password@localhost:3306/yessal_shared"

# JWT Secret (générez une clé sécurisée)
JWT_SECRET="your_jwt_secret_key_here"

# CORS Origins
CORS_ORIGIN="https://manager.yessal.sn,https://yessal.sn"

# Logs
LOG_LEVEL=info 