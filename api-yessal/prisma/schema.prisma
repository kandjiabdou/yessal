generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id                          Int                        @id @default(autoincrement())
  role                        userrole
  nom                         String
  prenom                      String
  email                       String?                    @unique
  telephone                   String?                    @unique
  motDePasseHash              String?
  loginGoogleId               String?
  adresseText                 String?
  latitude                    Float?
  longitude                   Float?
  aGeolocalisationEnregistree Boolean                    @default(false)
  typeClient                  typeclient?
  estEtudiant                 Boolean                    @default(false)
  siteLavagePrincipalGerantId Int?
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt
  flag                        Boolean                    @default(true)
  createdByUserId             Int?
  abonnementsPremium          abonnementpremiummensuel[]
  abonnementsCreePar          abonnementpremiummensuel[] @relation("AbonnementCreatedBy")
  clientsInvitesCreated       clientinvite[]
  commandesClient             commande[]                 @relation("CommandeClient")
  commandesCreees             commande[]                 @relation("CommandeGerantCreation")
  commandesRecues             commande[]                 @relation("CommandeGerantReception")
  fidelite                    fidelite?
  logsAdminActions            logadminaction[]
  createdBy                   user?                      @relation("UserCreatedBy", fields: [createdByUserId], references: [id])
  usersCreated                user[]                     @relation("UserCreatedBy")
  siteLavagePrincipal         sitelavage?                @relation(fields: [siteLavagePrincipalGerantId], references: [id])
  ventesClient                vente[]                    @relation("VenteClient")
  ventesEnregistrees          vente[]

  @@index([siteLavagePrincipalGerantId], map: "User_siteLavagePrincipalGerantId_fkey")
  @@index([createdByUserId], map: "User_createdByUserId_fkey")
  @@index([createdAt])
  @@index([createdAt, flag])
  @@index([flag])
}

model livreur {
  id                  Int        @id @default(autoincrement())
  nom                 String
  prenom              String
  email               String?
  telephone           String?
  adresseText         String?
  moyenLivraison      String?
  statutDisponibilite Boolean    @default(true)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @default(now())
  flag                Boolean    @default(true)
  commandes           commande[]
}

model sitelavage {
  id                Int                        @id @default(autoincrement())
  nom               String
  adresseText       String
  ville             String
  latitude          Float
  longitude         Float
  telephone         String?
  statutOuverture   Boolean                    @default(false)
  estLaverie        Boolean                    @default(true)
  estBoutique       Boolean                    @default(true)
  estVirtuel        Boolean                    @default(false)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @default(now())
  heureFermeture    String                     @default("20:00")
  heureOuverture    String                     @default("09:00")
  flag              Boolean                    @default(true)
  abonnements       abonnementpremiummensuel[]
  clientsInvites    clientinvite[]
  commandes         commande[]
  machines          machinelavage[]
  statsJournalieres statjournalsite[]
  stocksProduits    stockproduit[]
  gerants           user[]
  ventes            vente[]
}

model machinelavage {
  id           Int        @id @default(autoincrement())
  siteLavageId Int
  numero       Int
  nom          String?
  type         String
  poidsKg      Float
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now())
  flag         Boolean    @default(true)
  siteLavage   sitelavage @relation(fields: [siteLavageId], references: [id])

  @@index([siteLavageId], map: "MachineLavage_siteLavageId_fkey")
}

model clientinvite {
  id              Int         @id @default(autoincrement())
  nom             String?
  telephone       String?
  email           String?
  adresseText     String?
  prenom          String?
  flag            Boolean     @default(true)
  siteLavageId    Int?
  createdByUserId Int?
  createdBy       user?       @relation(fields: [createdByUserId], references: [id])
  siteLavage      sitelavage? @relation(fields: [siteLavageId], references: [id])
  commandes       commande[]

  @@index([createdByUserId], map: "ClientInvite_createdByUserId_fkey")
  @@index([siteLavageId], map: "ClientInvite_siteLavageId_fkey")
}

model adresselivraison {
  id          Int      @id @default(autoincrement())
  commandeId  Int
  adresseText String?
  latitude    Float?
  longitude   Float?
  flag        Boolean  @default(true)
  commande    commande @relation(fields: [commandeId], references: [id])

  @@index([commandeId], map: "AdresseLivraison_commandeId_fkey")
}

model commande {
  id                      Int                        @id @default(autoincrement())
  clientUserId            Int?
  clientInviteId          Int?
  siteLavageId            Int
  gerantCreationUserId    Int
  gerantReceptionUserId   Int?
  livreurId               Int?
  dateHeureCommande       DateTime
  dateDernierStatutChange DateTime
  statut                  commandestatut             @default(PrisEnCharge)
  masseClientIndicativeKg Float?
  masseVerifieeKg         Float?
  estEnLivraison          Boolean                    @default(false)
  prixTotal               Float?
  modePaiement            modepaiement?
  typeReduction           typereduction?
  formuleCommande         formulecommande
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  prixPaye                Float?
  ajustementMethode       ajustementmethode?
  ajustementRaison        String?
  ajustementType          ajustementtype?
  ajustementValeur        Float?
  flag                    Boolean                    @default(true)
  pointsUtilises          Int?                       @default(0)
  montantReductionPoints  Float?                     @default(0)
  adresseLivraison        adresselivraison[]
  clientInvite            clientinvite?              @relation(fields: [clientInviteId], references: [id])
  clientUser              user?                      @relation("CommandeClient", fields: [clientUserId], references: [id])
  gerantCreation          user                       @relation("CommandeGerantCreation", fields: [gerantCreationUserId], references: [id])
  gerantReception         user?                      @relation("CommandeGerantReception", fields: [gerantReceptionUserId], references: [id])
  livreur                 livreur?                   @relation(fields: [livreurId], references: [id])
  siteLavage              sitelavage                 @relation(fields: [siteLavageId], references: [id])
  options                 commandeoptions?
  historiqueStatuts       historiquestatutcommande[]
  paiements               paiement[]
  repartitionMachines     repartitionmachine[]

  @@index([clientInviteId], map: "Commande_clientInviteId_fkey")
  @@index([clientUserId], map: "Commande_clientUserId_fkey")
  @@index([gerantCreationUserId], map: "Commande_gerantCreationUserId_fkey")
  @@index([gerantReceptionUserId], map: "Commande_gerantReceptionUserId_fkey")
  @@index([livreurId], map: "Commande_livreurId_fkey")
  @@index([siteLavageId], map: "Commande_siteLavageId_fkey")
  @@index([dateHeureCommande])
  @@index([dateHeureCommande, flag])
  @@index([siteLavageId, dateHeureCommande])
  @@index([flag])
}

model commandeoptions {
  id               Int      @id @default(autoincrement())
  commandeId       Int      @unique
  aOptionRepassage Boolean  @default(false)
  aOptionSechage   Boolean  @default(false)
  aOptionLivraison Boolean  @default(false)
  aOptionExpress   Boolean  @default(false)
  flag             Boolean  @default(true)
  commande         commande @relation(fields: [commandeId], references: [id])
}

model repartitionmachine {
  id           Int      @id @default(autoincrement())
  commandeId   Int
  typeMachine  String
  quantite     Int
  prixUnitaire Float
  flag         Boolean  @default(true)
  commande     commande @relation(fields: [commandeId], references: [id])

  @@index([commandeId], map: "RepartitionMachine_commandeId_fkey")
}

model historiquestatutcommande {
  id                  Int            @id @default(autoincrement())
  commandeId          Int
  statut              commandestatut
  dateHeureChangement DateTime
  flag                Boolean        @default(true)
  commande            commande       @relation(fields: [commandeId], references: [id])

  @@index([commandeId], map: "HistoriqueStatutCommande_commandeId_fkey")
}

model paiement {
  id           Int            @id @default(autoincrement())
  commandeId   Int
  montant      Float
  mode         modepaiement
  datePaiement DateTime
  statut       statutpaiement
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now())
  flag         Boolean        @default(true)
  commande     commande       @relation(fields: [commandeId], references: [id])

  @@index([commandeId], map: "Paiement_commandeId_fkey")
}

model fidelite {
  id                  Int      @id @default(autoincrement())
  clientUserId        Int      @unique
  nombreLavageTotal   Int      @default(0)
  poidsTotalLaveKg    Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  numeroCarteFidelite String   @unique
  flag                Boolean  @default(true)
  prixTotalPaye       Float    @default(0)
  pointsDisponible    Int      @default(0)
  pointsFraction      Float    @default(0)
  creditDisponible    Float    @default(0)
  clientUser          user     @relation(fields: [clientUserId], references: [id])
}

model abonnementpremiummensuel {
  id              Int        @id @default(autoincrement())
  clientUserId    Int
  annee           Int
  mois            Int
  limiteKg        Float      @default(40)
  kgUtilises      Float      @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @default(now())
  flag            Boolean    @default(true)
  montant         Float      @default(15000)
  createdByUserId Int?
  siteLavageId    Int
  clientUser      user       @relation(fields: [clientUserId], references: [id])
  createdBy       user?      @relation("AbonnementCreatedBy", fields: [createdByUserId], references: [id])
  siteLavage      sitelavage @relation(fields: [siteLavageId], references: [id])

  @@unique([clientUserId, annee, mois])
  @@index([siteLavageId], map: "AbonnementSiteLavageId_fkey")
  @@index([createdByUserId], map: "AbonnementCreatedByUserId_fkey")
  @@index([createdAt])
  @@index([createdAt, flag])
  @@index([annee, mois, flag])
  @@index([siteLavageId, annee, mois, flag])
  @@index([flag])
}

model statjournalsite {
  id             Int        @id @default(autoincrement())
  siteLavageId   Int
  dateJour       DateTime
  totalCommandes Int
  totalPoidsKg   Float
  totalRevenue   Float
  createdAt      DateTime   @default(now())
  flag           Boolean    @default(true)
  siteLavage     sitelavage @relation(fields: [siteLavageId], references: [id])

  @@index([siteLavageId], map: "StatJournalSite_siteLavageId_fkey")
}

model logadminaction {
  id          Int      @id @default(autoincrement())
  adminUserId Int
  typeAction  String
  entite      String
  entiteId    Int
  description String
  dateAction  DateTime @default(now())
  flag        Boolean  @default(true)
  adminUser   user     @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId], map: "LogAdminAction_adminUserId_fkey")
}

model categorieproduit {
  id          Int       @id @default(autoincrement())
  nom         String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  flag        Boolean   @default(true)
  produits    produit[]
}

model produit {
  id            Int               @id @default(autoincrement())
  nom           String
  description   String?
  prixReference Float
  codeBarres    String?           @unique
  image         String?
  categorieId   Int?
  fournisseur   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  flag          Boolean           @default(true)
  lignesVente   lignevente[]
  packsVenteGros packventegros[]
  categorie     categorieproduit? @relation(fields: [categorieId], references: [id])
  stocksSites   stockproduit[]

  @@index([categorieId], map: "Produit_categorieId_fkey")
  @@index([codeBarres])
  @@index([flag])
}

model stockproduit {
  id              Int              @id @default(autoincrement())
  produitId       Int
  siteLavageId    Int
  stock           Int              @default(0)
  stockAlerte     Int              @default(10)
  prixVente       Float
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  flag            Boolean          @default(true)
  mouvementsStock mouvementstock[]
  produit         produit          @relation(fields: [produitId], references: [id])
  siteLavage      sitelavage       @relation(fields: [siteLavageId], references: [id])

  @@unique([produitId, siteLavageId])
  @@index([siteLavageId], map: "StockProduit_siteLavageId_fkey")
  @@index([produitId], map: "StockProduit_produitId_fkey")
  @@index([siteLavageId, flag])
  @@index([stock, stockAlerte])
  @@index([siteLavageId, stock])
}

model vente {
  id                Int              @id @default(autoincrement())
  numeroFacture     String
  siteLavageId      Int
  managerUserId     Int
  clientUserId      Int?
  dateVente         DateTime         @default(now())
  montantTotal      Float
  montantPaye       Float?
  modePaiement      modepaiement?
  nombreArticles    Int
  ajustementMethode ajustementmethode?
  ajustementRaison  String?
  ajustementType    ajustementtype?
  ajustementValeur  Float?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  flag              Boolean          @default(true)
  lignesVente       lignevente[]
  clientUser        user?            @relation("VenteClient", fields: [clientUserId], references: [id])
  manager           user             @relation(fields: [managerUserId], references: [id])
  siteLavage        sitelavage       @relation(fields: [siteLavageId], references: [id])

  @@unique([siteLavageId, numeroFacture])
  @@index([siteLavageId], map: "Vente_siteLavageId_fkey")
  @@index([managerUserId], map: "Vente_managerUserId_fkey")
  @@index([clientUserId], map: "Vente_clientUserId_fkey")
  @@index([dateVente])
  @@index([siteLavageId, dateVente])
  @@index([dateVente, flag])
  @@index([siteLavageId, dateVente, flag])
  @@index([numeroFacture])
  @@index([flag])
}

model lignevente {
  id              Int            @id @default(autoincrement())
  venteId         Int
  produitId       Int
  quantite        Int
  prixUnitaire    Float
  sousTotal       Float
  typeVente       typevente      @default(Detail)
  packVenteGrosId Int?
  createdAt       DateTime       @default(now())
  flag            Boolean        @default(true)
  packVenteGros   packventegros? @relation(fields: [packVenteGrosId], references: [id])
  produit         produit        @relation(fields: [produitId], references: [id])
  vente           vente          @relation(fields: [venteId], references: [id])

  @@index([venteId], map: "LigneVente_venteId_fkey")
  @@index([produitId], map: "LigneVente_produitId_fkey")
  @@index([packVenteGrosId], map: "LigneVente_packVenteGrosId_fkey")
  @@index([venteId, flag])
}

model mouvementstock {
  id             Int                @id @default(autoincrement())
  stockProduitId Int
  type           typemouvementstock
  quantite       Int
  motif          String?
  dateHeure      DateTime           @default(now())
  flag           Boolean            @default(true)
  stockProduit   stockproduit       @relation(fields: [stockProduitId], references: [id])

  @@index([stockProduitId], map: "MouvementStock_stockProduitId_fkey")
  @@index([dateHeure])
  @@index([stockProduitId, dateHeure])
  @@index([type, dateHeure])
}

model packventegros {
  id             Int          @id @default(autoincrement())
  produitId      Int
  nom            String
  quantiteUnites Int
  prixPack       Float
  actif          Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  flag           Boolean      @default(true)
  lignesVente    lignevente[]
  produit        produit      @relation(fields: [produitId], references: [id])

  @@index([produitId], map: "PackVenteGros_produitId_fkey")
  @@index([produitId, actif, flag])
}

enum typemouvementstock {
  Entree
  Sortie
  Ajustement
  Retour
}

enum userrole {
  CLIENT
  MANAGER
  ADMIN
}

enum typeclient {
  Standard
  Premium
}

enum commandestatut {
  PrisEnCharge
  LavageEnCours
  Repassage
  Livraison
  Livre
}

enum modepaiement {
  Espece
  MobileMoney
  Autre
}

enum typereduction {
  Ouverture
  Etudiant
}

enum formulecommande {
  BaseMachine
  Detail
}

enum typevente {
  Detail
  Gros
}

enum statutpaiement {
  EnAttente
  Paye
  Echoue
}

enum ajustementtype {
  Augmentation
  Diminution
}

enum ajustementmethode {
  Pourcentage
  Absolu
}
